# MySQL 数据库（部署时必改；使用 root 时填 root 密码即可）
DATABASE_HOST=localhost
DATABASE_PORT=3306
DATABASE_USER=root
DATABASE_PASSWORD=请填写MySQL密码
DATABASE_NAME=workmind

# RabbitMQ（Celery 消息队列）
MQ_USER=guest
MQ_PASSWORD=guest
MQ_HOST=127.0.0.1
MQ_PORT=5672

# Redis
REDIS_ON=True
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=
REDIS_PORT=6379
REDIS_DB=0

# Django（生产环境务必修改 SECRET_KEY，DEBUG 改为 False）
SECRET_KEY=请更换为随机密钥
DEBUG=False
ALLOWED_HOSTS=你的域名或服务器IP

KIMI_API_KEY=请填写KIMI_API_KEY
KIMI_BASE_URL=https://api.moonshot.cn/v1
KIMI_MODEL=kimi-k2.5
